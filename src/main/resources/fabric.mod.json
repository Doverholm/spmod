			"net.doverholm.spmod.SPMod"
		],
		"fabric-datagen": [
			"net.doverholm.spmod.SPModDataGenerator"
		],
		"client": [
			"net.doverholm.spmod.SPModClient"
		]
	},
	"mixins": [
		"spmod.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.1",
		"minecraft": "~1.21.1",
		"java": ">=21",
