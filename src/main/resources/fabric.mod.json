{
	"schemaVersion": 1,
	"id": "spmod",
	"version": "${version}",
	"name": "SP Mod",
	"description": "Moddet för Skånska Pågar SMP!",
	"authors": [
		"Martin Doverholm",
		"Charlie Doverholm"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/spmod/icon.png",
	"environment": "*",
